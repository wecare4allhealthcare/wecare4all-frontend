# ─────────────────────────────────────────────────────────────
#  We Care 4 All — Frontend Environment Variables
#  Copy this file to .env and update values
# ─────────────────────────────────────────────────────────────

# Backend API URL (update for production deployment)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Razorpay Public Key (add when purchased — Phase 3)
VITE_RAZORPAY_KEY_ID=rzp_test_your-key-here

# Stripe Public Key (add when purchased — Phase 3)
VITE_STRIPE_PUBLIC_KEY=pk_test_your-key-here

# Video App ID (add when purchased — Phase 4)
VITE_VIDEO_APP_ID=your-video-app-id
